{
  "manifest_version": 3,
  "name": "Doom Stalling",
  "version": "1.0.0",
  "description": "Stop doomscrolling. Take a moment to reconsider.",
  "permissions": ["storage", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "options.html",
    "default_title": "Doom Stalling Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["stall.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
